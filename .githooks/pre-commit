#!/usr/bin/env bash

set -e

java_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.java$' || true)

if [ -z "$java_files" ]; then
    exit 0
fi

echo "Running Spotless on staged Java files..."

if ! ./gradlew spotlessApply --quiet; then
    echo "Spotless formatting failed."
    exit 1
fi

echo "$java_files" | xargs git add
echo "Spotless formatting applied and files re-staged."
